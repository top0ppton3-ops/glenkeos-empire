{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "EventEnvelope",
  "description": "Universal event envelope for all domain events",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "type": {
      "type": "string",
      "description": "Event type name"
    },
    "entityType": {
      "type": "string",
      "enum": ["order", "store", "driver", "staff", "policy", "riskEvent", "inventoryItem", "customer", "metric"],
      "description": "Type of entity this event relates to"
    },
    "entityId": {
      "type": "string",
      "description": "ID of the entity this event relates to"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the event occurred"
    },
    "actorId": {
      "type": ["string", "null"],
      "description": "ID of the actor that triggered the event (staff, system, customer)"
    },
    "actorType": {
      "type": "string",
      "enum": ["STAFF", "SYSTEM", "API", "CUSTOMER"],
      "description": "Type of actor"
    },
    "metadata": {
      "type": "object",
      "description": "Event-specific payload data"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "Event schema version"
    },
    "correlationId": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Links related events together"
    }
  },
  "required": [
    "id",
    "type",
    "entityType",
    "entityId",
    "timestamp",
    "actorType",
    "metadata",
    "version"
  ]
}
