  "envelope": {
    "version": "1.0",
    "description": "Standard event envelope for all GlenKeos events",
    "schema": {
      "event_id": "string (UUID)",
      "event_type": "string",
      "event_version": "string",
      "event_source": "string",
      "timestamp": "string (ISO 8601)",
      "correlation_id": "string (UUID)",
      "causation_id": "string (UUID, optional)",
      "tenant_id": "string",
      "metadata": {
        "actor_id": "string (optional)",
        "actor_type": "string (optional)",
        "ip_address": "string (optional)",
        "user_agent": "string (optional)"
      },
      "payload": "object (event-specific data)"
    }
  },
  "routing_rules": [
    {
      "rule_name": "all-events-to-compliance",
      "description": "Route all events to compliance service for audit trail",
      "pattern": {
        "source": ["*"]
      },
      "targets": ["compliance-service"]
    },
    {
      "rule_name": "critical-events-to-metrics",
      "description": "Route critical business events to metrics service",
      "pattern": {
        "detail-type": [
          "ORDER_CREATED",
          "ORDER_COMPLETED",
          "PAYMENT_COMPLETED",
          "PAYMENT_FAILED"
        ]
      },
      "targets": ["metrics-service"]
    },
    {
      "rule_name": "customer-notifications",
      "description": "Route customer-facing events to notifications service",
      "pattern": {
        "detail-type": [
          "ORDER_CREATED",
          "ORDER_ACCEPTED",
          "ORDER_READY",
          "ORDER_OUT_FOR_DELIVERY",
          "ORDER_COMPLETED",
          "PAYMENT_COMPLETED",
          "REWARD_EARNED"
        ]
      },
      "targets": ["notifications-service"]
    },
    {
      "rule_name": "inventory-alerts",
      "description": "Route inventory alerts to notifications service",
      "pattern": {
        "detail-type": ["STOCK_LOW", "STOCK_CRITICAL"]
      },
      "targets": ["notifications-service"]
    }
  ]
