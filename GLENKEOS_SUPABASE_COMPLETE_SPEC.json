      "Role-based access control"
    ],
    "frontend_usage": "Use Supabase client: supabase.auth.signInWithPassword()",
    "protected_routes": "Pass access_token in Authorization header"
  },
  "storage_architecture": {
    "type": "Supabase KV Store",
    "namespacing_pattern": "resource_type:identifier",
    "examples": [
      "customer:uuid",
      "order:uuid",
      "driver:uuid",
      "metric:metric_name:uuid:timestamp",
      "compliance:event_type:uuid:timestamp",
      "grc:policy:uuid",
      "grc:risk:uuid"
    ],
    "indexing": "Prefix-based queries via getByPrefix()",
    "flexibility": "JSON-serializable data, no schema migrations required"
  },
  "event_catalog": {
    "ORDER_CREATED": "Logged when new order is created",
    "ORDER_STATUS_CHANGED": "Logged on status transitions",
    "DRIVER_ASSIGNED": "Logged when driver assigned to order",
    "PAYMENT_PROCESSED": "Logged when payment completes",
    "LOW_STOCK_ALERT": "Triggered when inventory below threshold"
  },
  "deployment": {
