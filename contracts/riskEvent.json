{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "RiskEvent",
  "description": "Risk event requiring monitoring or mitigation",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^risk_[a-zA-Z0-9]+$",
      "description": "Unique risk event identifier"
    },
    "type": {
      "type": "string",
      "const": "riskEvent"
    },
    "attributes": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "status": {
          "type": "string",
          "enum": ["OPEN", "IN_REVIEW", "MITIGATED", "RESOLVED", "ESCALATED"]
        },
        "category": {
          "type": "string",
          "enum": [
            "FRAUD",
            "FOOD_SAFETY",
            "OPERATIONAL",
            "FINANCIAL",
            "REPUTATIONAL",
            "COMPLIANCE",
            "SECURITY",
            "OTHER"
          ]
        },
        "entityType": {
          "type": "string",
          "enum": ["order", "store", "driver", "staff", "customer", "inventory"]
        },
        "entityId": {
          "type": "string",
          "description": "ID of the entity this risk is related to"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string"
        },
        "indicators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "value": { "type": ["string", "number", "boolean"] },
              "threshold": { "type": ["string", "number"] }
            }
          }
        },
        "mitigationSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "assignedTo": { "type": "string", "pattern": "^staff_[a-zA-Z0-9]+$" },
              "status": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED"] },
              "completedAt": { "type": ["string", "null"], "format": "date-time" }
            }
          }
        },
        "detectedBy": {
          "type": "string",
          "description": "System or staff ID that detected the risk"
        },
        "assignedTo": {
          "type": ["string", "null"],
          "pattern": "^staff_[a-zA-Z0-9]+$"
        },
        "resolvedBy": {
          "type": ["string", "null"],
          "pattern": "^staff_[a-zA-Z0-9]+$"
        },
        "resolvedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "severity",
        "status",
        "category",
        "entityType",
        "entityId",
        "title",
        "description",
        "createdAt",
        "updatedAt"
      ]
    },
    "relationships": {
      "type": "object",
      "properties": {
        "entity": { "type": "string" },
        "assignee": { "type": ["string", "null"], "pattern": "^staff_[a-zA-Z0-9]+$" },
        "resolver": { "type": ["string", "null"], "pattern": "^staff_[a-zA-Z0-9]+$" }
      }
    },
    "meta": {
      "type": "object"
    }
  },
  "required": ["id", "type", "attributes"]
}
