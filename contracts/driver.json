{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Driver",
  "description": "Delivery driver in GlenKeos system",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^drv_[a-zA-Z0-9]+$",
      "description": "Unique driver identifier"
    },
    "type": {
      "type": "string",
      "const": "driver"
    },
    "attributes": {
      "type": "object",
      "properties": {
        "storeId": {
          "type": "string",
          "pattern": "^store_[a-zA-Z0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "phone": {
          "type": "string",
          "pattern": "^\\+?[1-9]\\d{1,14}$"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "status": {
          "type": "string",
          "enum": ["ONLINE", "OFFLINE", "BUSY", "ON_BREAK", "INACTIVE"]
        },
        "vehicle": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["CAR", "BIKE", "MOTORCYCLE", "SCOOTER", "WALK"] },
            "make": { "type": "string" },
            "model": { "type": "string" },
            "year": { "type": "integer" },
            "licensePlate": { "type": "string" },
            "color": { "type": "string" }
          },
          "required": ["type"]
        },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
            "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
            "lastUpdated": { "type": "string", "format": "date-time" }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "totalDeliveries": { "type": "integer", "minimum": 0 },
            "rating": { "type": "number", "minimum": 0, "maximum": 5 },
            "totalRatings": { "type": "integer", "minimum": 0 },
            "onTimePercentage": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },
        "currentOrderId": {
          "type": ["string", "null"],
          "pattern": "^ord_[a-zA-Z0-9]+$"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "storeId",
        "name",
        "phone",
        "status",
        "vehicle",
        "createdAt",
        "updatedAt"
      ]
    },
    "relationships": {
      "type": "object",
      "properties": {
        "store": { "type": "string", "pattern": "^store_[a-zA-Z0-9]+$" },
        "currentOrder": { "type": ["string", "null"], "pattern": "^ord_[a-zA-Z0-9]+$" }
      }
    },
    "meta": {
      "type": "object"
    }
  },
  "required": ["id", "type", "attributes"]
}
