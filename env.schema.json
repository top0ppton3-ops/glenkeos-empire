{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GlenKeos Environment Configuration Schema",
  "description": "Complete environment variable schema for GlenKeos enterprise platform. All variables are typed, documented, and validated.",
  "type": "object",
  "required": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY"
  ],
  "properties": {
    "VITE_SUPABASE_URL": {
      "type": "string",
      "format": "uri",
      "description": "Supabase project URL (public, safe to expose in frontend)",
      "example": "https://beswluhdxaphtitaovly.supabase.co",
      "pattern": "^https://[a-z0-9]+\\.supabase\\.co$"
    },
    "VITE_SUPABASE_ANON_KEY": {
      "type": "string",
      "description": "Supabase anonymous/public API key (public, safe to expose in frontend). RLS enforces security.",
      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "minLength": 100,
      "pattern": "^eyJ[A-Za-z0-9-_=]+\\.[A-Za-z0-9-_=]+\\.[A-Za-z0-9-_.+/=]*$"
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "type": "string",
      "description": "Supabase service role key (BACKEND ONLY - bypasses RLS). NEVER expose in frontend. Use only in Edge Functions or CI/CD.",
      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "minLength": 100,
      "pattern": "^eyJ[A-Za-z0-9-_=]+\\.[A-Za-z0-9-_=]+\\.[A-Za-z0-9-_.+/=]*$",
      "secret": true
    },
    "DATABASE_URL": {
      "type": "string",
      "format": "uri",
      "description": "PostgreSQL connection string (BACKEND ONLY - contains password). Never expose in frontend.",
      "example": "postgresql://postgres:password@db.supabase.co:5432/postgres",
      "pattern": "^postgresql://",
      "secret": true
    },
    "PAYPAL_CLIENT_ID": {
      "type": "string",
      "description": "PayPal REST API client ID for payment processing",
      "example": "AYSq3RDGsmBLJE-otTkBtM-jBRd1TCQwFf9RGfwddNXWz0uFU9ztymylOhRS",
      "minLength": 50,
      "secret": false
    },
    "PAYPAL_CLIENT_SECRET": {
      "type": "string",
      "description": "PayPal REST API client secret (BACKEND ONLY - highly sensitive)",
      "example": "EGnHDxD_qRPdaLdZz8iCr8N7_MzF-YHPTkjs6NKYQvQSBngp4PTTVWkPZRbL",
      "minLength": 50,
      "secret": true
    },
    "PAYPAL_MODE": {
      "type": "string",
      "enum": ["sandbox", "live"],
      "description": "PayPal API mode (sandbox for testing, live for production)",
      "default": "sandbox"
    },
    "STRIPE_PUBLISHABLE_KEY": {
      "type": "string",
      "description": "Stripe publishable API key (public, safe to expose in frontend)",
      "example": "pk_live_51H8...",
      "pattern": "^pk_(test|live)_[A-Za-z0-9]+$",
      "secret": false
    },
    "STRIPE_SECRET_KEY": {
      "type": "string",
      "description": "Stripe secret API key (BACKEND ONLY - highly sensitive)",
      "example": "sk_live_51H8...",
      "pattern": "^sk_(test|live)_[A-Za-z0-9]+$",
      "secret": true
    },
    "STRIPE_WEBHOOK_SECRET": {
      "type": "string",
      "description": "Stripe webhook signing secret for verifying webhook signatures",
      "example": "whsec_...",
      "pattern": "^whsec_[A-Za-z0-9]+$",
      "secret": true
    },
    "TWILIO_ACCOUNT_SID": {
      "type": "string",
      "description": "Twilio account SID for SMS notifications",
      "example": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "pattern": "^AC[a-z0-9]{32}$"
    },
    "TWILIO_AUTH_TOKEN": {
      "type": "string",
      "description": "Twilio authentication token (BACKEND ONLY)",
      "example": "your_auth_token_here",
      "minLength": 32,
      "secret": true
    },
    "TWILIO_PHONE_NUMBER": {
      "type": "string",
      "description": "Twilio phone number for sending SMS (E.164 format)",
      "example": "+14155551234",
      "pattern": "^\\+[1-9]\\d{1,14}$"
    },
    "SENDGRID_API_KEY": {
      "type": "string",
      "description": "SendGrid API key for transactional emails (BACKEND ONLY)",
      "example": "SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "pattern": "^SG\\.[A-Za-z0-9_-]+$",
      "secret": true
    },
    "SENDGRID_FROM_EMAIL": {
      "type": "string",
      "format": "email",
      "description": "Verified sender email address for SendGrid",
      "example": "noreply@glenkeos.com"
    },
    "RESEND_API_KEY": {
      "type": "string",
      "description": "Resend API key for transactional emails (alternative to SendGrid)",
      "example": "re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "pattern": "^re_[A-Za-z0-9]+$",
      "secret": true
    },
    "SENTRY_DSN": {
      "type": "string",
      "format": "uri",
      "description": "Sentry Data Source Name for error tracking (public, safe to expose)",
      "example": "https://examplePublicKey@o0.ingest.sentry.io/0",
      "pattern": "^https://[a-z0-9]+@[a-z0-9.]+/[0-9]+$"
    },
    "SENTRY_AUTH_TOKEN": {
      "type": "string",
      "description": "Sentry authentication token for source map uploads (BACKEND ONLY)",
      "example": "sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "secret": true
    },
    "SENTRY_ORG": {
      "type": "string",
      "description": "Sentry organization slug",
      "example": "glenkeos"
    },
    "SENTRY_PROJECT": {
      "type": "string",
      "description": "Sentry project slug",
      "example": "glenkeos-platform"
    },
    "VITE_APP_ENV": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Application environment",
      "default": "development"
    },
    "VITE_API_BASE_URL": {
      "type": "string",
      "format": "uri",
      "description": "Base URL for API requests",
      "example": "https://beswluhdxaphtitaovly.supabase.co/rest/v1"
    },
    "VITE_FUNCTIONS_BASE_URL": {
      "type": "string",
      "format": "uri",
      "description": "Base URL for Supabase Edge Functions",
      "example": "https://beswluhdxaphtitaovly.supabase.co/functions/v1"
    },
    "VITE_ENABLE_ANALYTICS": {
      "type": "boolean",
      "description": "Enable analytics tracking (Google Analytics, Mixpanel, etc.)",
      "default": false
    },
    "VITE_GOOGLE_ANALYTICS_ID": {
      "type": "string",
      "description": "Google Analytics measurement ID",
      "example": "G-XXXXXXXXXX",
      "pattern": "^G-[A-Z0-9]+$"
    },
    "VITE_ENABLE_DEBUG": {
      "type": "boolean",
      "description": "Enable debug logging in console",
      "default": false
    },
    "VITE_ENABLE_REALTIME": {
      "type": "boolean",
      "description": "Enable Supabase Realtime WebSocket subscriptions",
      "default": true
    },
    "VERCEL_URL": {
      "type": "string",
      "description": "Vercel deployment URL (automatically set by Vercel)",
      "example": "glenkeos-abc123.vercel.app"
    },
    "VERCEL_ENV": {
      "type": "string",
      "enum": ["production", "preview", "development"],
      "description": "Vercel environment (automatically set by Vercel)"
    },
    "VERCEL_GIT_COMMIT_SHA": {
      "type": "string",
      "description": "Git commit SHA for this deployment (automatically set by Vercel)",
      "pattern": "^[a-f0-9]{40}$"
    },
    "CI": {
      "type": "boolean",
      "description": "Running in CI/CD environment",
      "default": false
    },
    "NODE_ENV": {
      "type": "string",
      "enum": ["development", "test", "production"],
      "description": "Node.js environment",
      "default": "development"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "environments": {
      "development": {
        "required": [
          "VITE_SUPABASE_URL",
          "VITE_SUPABASE_ANON_KEY"
        ],
        "description": "Minimum required for local development"
      },
      "staging": {
        "required": [
          "VITE_SUPABASE_URL",
          "VITE_SUPABASE_ANON_KEY",
          "PAYPAL_CLIENT_ID",
          "PAYPAL_CLIENT_SECRET",
          "TWILIO_ACCOUNT_SID",
          "TWILIO_AUTH_TOKEN",
          "SENDGRID_API_KEY"
        ],
        "description": "Required for staging environment (all integrations)"
      },
      "production": {
        "required": [
          "VITE_SUPABASE_URL",
          "VITE_SUPABASE_ANON_KEY",
          "SUPABASE_SERVICE_ROLE_KEY",
          "DATABASE_URL",
          "PAYPAL_CLIENT_ID",
          "PAYPAL_CLIENT_SECRET",
          "STRIPE_PUBLISHABLE_KEY",
          "STRIPE_SECRET_KEY",
          "STRIPE_WEBHOOK_SECRET",
          "TWILIO_ACCOUNT_SID",
          "TWILIO_AUTH_TOKEN",
          "TWILIO_PHONE_NUMBER",
          "SENDGRID_API_KEY",
          "SENDGRID_FROM_EMAIL",
          "SENTRY_DSN",
          "VITE_APP_ENV",
          "VITE_API_BASE_URL",
          "VITE_FUNCTIONS_BASE_URL"
        ],
        "description": "Required for production deployment (all features enabled)"
      }
    }
  },
  "security": {
    "sensitive_variables": [
      "SUPABASE_SERVICE_ROLE_KEY",
      "DATABASE_URL",
      "PAYPAL_CLIENT_SECRET",
      "STRIPE_SECRET_KEY",
      "STRIPE_WEBHOOK_SECRET",
      "TWILIO_AUTH_TOKEN",
      "SENDGRID_API_KEY",
      "RESEND_API_KEY",
      "SENTRY_AUTH_TOKEN"
    ],
    "public_variables": [
      "VITE_SUPABASE_URL",
      "VITE_SUPABASE_ANON_KEY",
      "PAYPAL_CLIENT_ID",
      "STRIPE_PUBLISHABLE_KEY",
      "SENTRY_DSN",
      "VITE_APP_ENV",
      "VITE_API_BASE_URL",
      "VITE_FUNCTIONS_BASE_URL",
      "VITE_ENABLE_ANALYTICS",
      "VITE_GOOGLE_ANALYTICS_ID",
      "VITE_ENABLE_DEBUG",
      "VITE_ENABLE_REALTIME"
    ],
    "rules": [
      "Variables prefixed with VITE_ are bundled into frontend code and are PUBLIC",
      "Never commit .env files to version control (use .env.example as template)",
      "Use Vercel environment variables for production secrets",
      "Use Supabase secrets for Edge Function environment variables",
      "Rotate all secrets every 90 days (compliance requirement)",
      "Use different credentials for development, staging, and production"
    ]
  },
  "validation": {
    "instructions": "Validate environment variables on application startup using this schema. Fail fast if required variables are missing or invalid.",
    "example_usage_typescript": "import Ajv from 'ajv'; import schema from './env.schema.json'; const ajv = new Ajv(); const validate = ajv.compile(schema); const valid = validate(process.env); if (!valid) { console.error('Environment validation failed:', validate.errors); process.exit(1); }"
  }
}
