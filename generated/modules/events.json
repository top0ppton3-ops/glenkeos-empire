{
  "envelope": {
    "id": {
      "type": "uuid",
      "required": true,
      "description": "Unique event identifier"
    },
    "type": {
      "type": "string",
      "required": true,
      "description": "Event type name"
    },
    "entityType": {
      "type": "string",
      "required": true,
      "description": "Type of entity this event is about"
    },
    "entityId": {
      "type": "string",
      "required": true,
      "description": "ID of the entity this event is about"
    },
    "timestamp": {
      "type": "ISO-8601",
      "required": true,
      "description": "Event creation timestamp"
    },
    "actorId": {
      "type": "string",
      "required": false,
      "description": "ID of the actor who triggered this event"
    },
    "actorType": {
      "type": "enum",
      "values": ["STAFF", "SYSTEM", "API", "CUSTOMER"],
      "required": true,
      "description": "Type of actor who triggered this event"
    },
    "metadata": {
      "type": "object",
      "required": true,
      "description": "Additional event metadata"
    },
    "version": {
      "type": "string",
      "required": true,
      "description": "Event schema version"
    },
    "correlationId": {
      "type": "uuid",
      "required": false,
      "description": "Correlation ID for distributed tracing"
    },
    "tenantId": {
      "type": "string",
      "required": false,
      "description": "Tenant ID for multi-tenant isolation"
    },
    "regionId": {
      "type": "string",
      "required": true,
      "description": "Region ID where event was generated"
    }
  },
  "catalog": [
